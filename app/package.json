{
  "name": "c4lens-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "cd ../crates/c4lens-tauri && tauri",
    "tauri:dev": "cd ../crates/c4lens-tauri && tauri dev",
    "tauri:build": "cd ../crates/c4lens-tauri && tauri build",
    "tauri:build:macos": "cd ../crates/c4lens-tauri && tauri build --target universal-apple-darwin --bundles app,dmg --ci --no-sign"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@xyflow/react": "12.11.1",
    "elkjs": "0.11.1",
    "lucide-react": "1.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
